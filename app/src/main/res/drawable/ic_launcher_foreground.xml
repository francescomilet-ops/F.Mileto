<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer Glow -->
    <path android:pathData="M54,54m-40,0a40,40 0,1 1,80 0a40,40 0,1 1,-80 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="40">
                <item android:color="#77E91E63" android:offset="0.0" />
                <item android:color="#00E91E63" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Bright Orb -->
    <path android:pathData="M54,54m-26,0a26,26 0,1 1,52 0a26,26 0,1 1,-52 0">
         <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="28"
                android:startY="28"
                android:endX="80"
                android:endY="80">
                <item android:color="#FF00FF" android:offset="0.0" />
                <item android:color="#00FFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Top Highlight Curve for 3D effect -->
    <path android:pathData="M54,32c-10,0 -18,6 -21,14c3,-6 10,-10 18,-10s15,4 18,10c-3,-8 -11,-14 -21,-14z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54"
                android:startY="32"
                android:endX="54"
                android:endY="46">
                <item android:color="#CCFFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
